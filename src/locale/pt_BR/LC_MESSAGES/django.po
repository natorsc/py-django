msgid ""
"\n"
"    <h1>Sent</h1>\n"
"    <p>We will email you instructions for setting your password.</p>\n"
"    <p class=\"text-warning\">Remember to check your spam folder.</p>\n"
"    "
msgstr ""
"\n"
"<h1>Enviado</h1>\n"
