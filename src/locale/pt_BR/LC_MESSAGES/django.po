#: src/base/templates/registration/password_reset_confirm.html:10
msgid ""
"\n"
"    <h1>Password change failed</h1>\n"
"    <p>The link used to change the password is <b>invalid</b>.</p>\n"
"    <p>This occurred because this link has already been used.</p>\n"
"    <p>Request a new password reset.</p>\n"
"    "
msgstr ""
"\n"
"<h1>Falha na alteração da senha</h1>\n"
"<p>O link usado para alterar a senha é <b>inválido</b>.</p>\n"
"<p>Isso ocorreu porque este link já foi usado.</p>\n"
"<p>Solicite uma nova redefinição de senha.</p>"

